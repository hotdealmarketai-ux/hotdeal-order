// 핫딜마켓 발주 플랫폼 — Prisma schema
// roles/categories/status 는 문자열 + 앱 레벨 상수(src/lib/constants.ts)로 관리.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel-Neon 통합이 만든 변수명 사용(앱 런타임/빌드가 직접 읽음).
  // 로컬은 .env 에서 같은 이름으로 로컬 Postgres 를 가리킴.
  url       = env("hotdealorder_POSTGRES_PRISMA_URL") // pooled (앱)
  directUrl = env("hotdealorder_DATABASE_URL_UNPOOLED") // direct (마이그레이션)
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique // 아이디
  passwordHash String
  // role: APPLICANT | MERCHANT_HOTDEAL | MERCHANT_SEOBU | VENDOR_SEOBU | VENDOR_JANGHEUNG | VENDOR_CHAEUMCHAE | ADMIN_SAEROP
  role         String   @default("APPLICANT")
  // status: PENDING | APPROVED | REJECTED
  status       String   @default("PENDING")

  storeName    String // 상호명
  phone        String // 연락처
  address      String // 업장 소재지
  businessCert String? // 사업자등록증 파일 경로/URL

  // 입금 자동매칭용 — 이 점포가 입금 시 통장에 찍히는 입금자명(상호·대표자명·직원명 등, 여러 개)
  payerNames   String[] @default([])

  orders          Order[]
  pushSubs        PushSubscription[]
  matchedDeposits Deposit[]
  invoices        Invoice[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 웹 푸시 구독 — 사용자 기기별 1개 (알림 발송 대상)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])

  category    String // FRUIT | VEG | TOOL | TOFU
  vendorRole  String // 목적지 업자 role (조회 편의를 위한 비정규화)
  pickupTime  String? // 서부일광 타 소매업자 전용

  status      String      @default("RECEIVED") // RECEIVED | DONE
  confirmed   Boolean     @default(false) // 업자가 '발주 확인' 눌렀는지
  confirmedAt DateTime?
  edited      Boolean     @default(false) // 점주가 발주 후 수정했는지
  editedAt    DateTime?
  rawText     String      @default("") // 점주가 입력한 원본(직렬화)
  aiSummary   String      @default("") // AI 사무적 요약(전체 노트)
  aiProcessed Boolean     @default(false)
  aiEngine    String      @default("none") // claude | rule | none

  items       OrderItem[]
  createdAt   DateTime    @default(now())

  @@index([vendorRole, createdAt])
  @@index([userId, createdAt])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(0)

  // 점주 원본
  rawName String @default("") // 품목
  rawQty  String @default("") // 수량
  rawNote String @default("") // 부연설명(등급/다이 등 요청)

  // AI 정리본 (사무적/정갈하게)
  name String @default("") // 정리된 품목
  qty  String @default("") // 정리된 수량
  note String @default("") // 정리된 부연설명
}

// 재고현황 — 새롭(본사)이 작성, 핫딜마켓 가맹점만 열람
model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("") // 상태/수량 텍스트
  memo      String   @default("")
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

// 계산서(장끼) — 새롭이 '실제 출고 기준'으로 직접 작성해 점포에 청구.
// 발주 리스트는 참고만(경매·생물 특성상 출고가 주문과 다름). 발행 후 수정 금지(취소→재작성).
model Invoice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  date   String // 출고 기준일 (KST, YYYY-MM-DD) — 합본 발주서 날짜와 동일 단위

  // status: DRAFT(작성중) | ISSUED(발행·입금대기) | PAID(입금확인) | VOID(취소)
  status String @default("DRAFT")
  total  Int    @default(0) // 합계(원) — 서버가 단가×수량으로 계산
  memo   String @default("")

  issuedAt DateTime?
  paidAt   DateTime?
  voidedAt DateTime?

  items     InvoiceItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, date])
  @@index([status, issuedAt])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  category  String // FRUIT | VEG | TOOL | TOFU — 카테고리별 섹션 표기
  sortOrder Int     @default(0)

  name      String // 품목
  qty       Float  @default(0) // 수량(소수 허용 — kg 등)
  unitPrice Int    @default(0) // 단가(원)
  amount    Int    @default(0) // 금액 = round(수량 × 단가), 서버 계산
}

// 입금 내역 — 팝빌 계좌조회로 수집한 하나 법인계좌 입금 건(자동 매칭 대상)
model Deposit {
  id           String    @id @default(cuid())
  bankTid      String    @unique // 팝빌 거래 고유 ID(중복 수집 방지)
  txAt         DateTime // 거래일시
  amount       Int // 입금액(원)
  payerName    String    @default("") // 입금자명(적요에서 추출)
  memo         String    @default("") // 적요/메모 원본
  balanceAfter Int? // 거래후 잔액
  // matchStatus: UNMATCHED | AUTO | MANUAL | IGNORED
  matchStatus  String    @default("UNMATCHED")
  matchedUserId String?
  matchedUser  User?     @relation(fields: [matchedUserId], references: [id], onDelete: SetNull)
  matchedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([matchStatus, txAt])
  @@index([matchedUserId])
}
