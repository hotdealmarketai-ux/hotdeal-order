// 핫딜마켓 발주 플랫폼 — Prisma schema
// roles/categories/status 는 문자열 + 앱 레벨 상수(src/lib/constants.ts)로 관리.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel-Neon 통합이 만든 변수명 사용(앱 런타임/빌드가 직접 읽음).
  // 로컬은 .env 에서 같은 이름으로 로컬 Postgres 를 가리킴.
  url       = env("hotdealorder_POSTGRES_PRISMA_URL") // pooled (앱)
  directUrl = env("hotdealorder_DATABASE_URL_UNPOOLED") // direct (마이그레이션)
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique // 아이디
  passwordHash String
  // role: APPLICANT | MERCHANT_HOTDEAL | MERCHANT_SEOBU | VENDOR_SEOBU | VENDOR_JANGHEUNG | VENDOR_CHAEUMCHAE | ADMIN_SAEROP
  role         String   @default("APPLICANT")
  // status: PENDING | APPROVED | REJECTED
  status       String   @default("PENDING")

  storeName    String // 상호명
  phone        String // 연락처
  address      String // 업장 소재지
  businessCert String? // 사업자등록증 파일 경로/URL

  // 입금 자동매칭용 — 이 점포가 입금 시 통장에 찍히는 예금주/입금자명(가입 시 입력, 여러 개)
  payerNames   String[] @default([])
  // 미수 잠금 1회성 해제(관리자가 임의 출고 시) — 미납 계산서가 있어도 발주 허용
  orderUnlock  Boolean  @default(false)
  // 해제한 시각 — 그 '발주창'에만 유효(1회성). 다음 창엔 미수가 남아있으면 다시 잠긴다.
  orderUnlockAt DateTime?

  // 주간발주 미수 잠금 1회성 해제(일일 발주 잠금과 독립) — 주간 미납이 있어도 이번 주간발주 허용
  weeklyOrderUnlock   Boolean   @default(false)
  weeklyOrderUnlockAt DateTime?

  orders          Order[]
  weeklyOrders    WeeklyOrder[]
  reservationOrders ReservationOrder[]
  pushSubs        PushSubscription[]
  matchedDeposits Deposit[]
  invoices        Invoice[]
  notifications   Notification[]
  chatThread      ChatThread?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 1:1 문의 채팅 — 가맹점주 1명당 스레드 1개(관리자 조직과 대화). #9
model ChatThread {
  id                String   @id @default(cuid())
  merchantId        String   @unique
  merchant          User     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  lastMessageAt     DateTime @default(now())
  // 자기 화면에서만 비우기(soft) — 이 시각 이전 메시지는 해당 측 화면에서 숨김
  merchantClearedAt DateTime?
  adminClearedAt    DateTime?
  createdAt         DateTime @default(now())
  messages          ChatMessage[]

  @@index([lastMessageAt])
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  fromAdmin Boolean // true=관리자 발신, false=가맹점주 발신
  body      String
  readAt    DateTime? // 수신자가 읽은 시각
  createdAt DateTime   @default(now())

  @@index([threadId, createdAt])
}

// 인앱 알림 — 푸시 발송과 동시에 유저당 1행 적재(기기 수와 무관). 알림목록(#10)·미읽음 배지(#8)의 소스.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String    @default("")
  url       String? // 클릭 시 이동 경로
  type      String    @default("") // order | invoice | deposit | weekly | chat | system
  readAt    DateTime? // null = 안읽음
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// 웹 푸시 구독 — 사용자 기기별 1개 (알림 발송 대상)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])

  category    String // FRUIT | VEG | TOOL | TOFU
  vendorRole  String // 목적지 업자 role (조회 편의를 위한 비정규화)
  pickupTime  String? // 서부일광 타 소매업자 전용

  status      String      @default("RECEIVED") // RECEIVED | DONE | CANCELLED
  confirmed   Boolean     @default(false) // 업자가 '발주 확인' 눌렀는지
  confirmedAt DateTime?
  edited      Boolean     @default(false) // 점주가 발주 후 수정했는지
  editedAt    DateTime?
  // 취소 흐름 — 점주가 '취소 요청'(cancelRequested) → 관리자 승인/임의취소 시 status=CANCELLED
  cancelRequested   Boolean   @default(false)
  cancelRequestedAt DateTime?
  cancelledAt       DateTime?
  rawText     String      @default("") // 점주가 입력한 원본(직렬화)
  aiSummary   String      @default("") // AI 사무적 요약(전체 노트)
  aiProcessed Boolean     @default(false)
  aiEngine    String      @default("none") // claude | rule | none

  items       OrderItem[]
  createdAt   DateTime    @default(now())

  @@index([vendorRole, createdAt])
  @@index([userId, createdAt])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(0)

  // 점주 원본
  rawName String @default("") // 품목
  rawQty  String @default("") // 수량
  rawNote String @default("") // 부연설명(등급/다이 등 요청)

  // AI 정리본 (사무적/정갈하게)
  name String @default("") // 정리된 품목
  qty  String @default("") // 정리된 수량
  note String @default("") // 정리된 부연설명
}

// 주간발주 — 매주 토요일 12~20시 1회, 항시품목(과자류/유제품/건어물/계란) 카탈로그 체크리스트.
// 일일 발주(Order)와 완전 분리. 주(週)당 점포 1건(weekKey=그 주 토요일 KST 날짜).
model WeeklyOrder {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  weekKey String // 그 주간창 시작일(토요일, KST YYYY-MM-DD)

  // 상태: 점주가 넣으면 confirmed=false(발주 요청) → 관리자 '발주 확인' 시 true → 이후 계산서 발행.
  // 점주가 수정하면 confirmed=false로 되돌림(관리자에 '수정 요청'으로 표시).
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?
  edited    Boolean   @default(false)
  editedAt  DateTime?
  items     WeeklyOrderItem[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, weekKey]) // 주당 점포 1건(원자적 중복 방지)
  @@index([weekKey, createdAt])
}

model WeeklyOrderItem {
  id            String      @id @default(cuid())
  weeklyOrderId String
  weeklyOrder   WeeklyOrder @relation(fields: [weeklyOrderId], references: [id], onDelete: Cascade)
  sortOrder     Int         @default(0)

  code      String // 카탈로그 seq(예: S01)
  category  String // SNACK | DAIRY | DRIED | EGG
  name      String
  boxUnit   String @default("")
  qty       Int    @default(0) // 발주 박스 수
  unitPrice Int    @default(0) // 발주 시점 박스 공급가 스냅샷(원)
}

// 주간발주 상품 카탈로그(DB) — 관리자가 추가/삭제/수정. 정적 파일(weekly-catalog.ts)에서 시드.
model WeeklyProduct {
  code        String   @id @default(cuid())
  category    String // SNACK | DAIRY | DRIED | EGG
  name        String
  perBox      Int      @default(1) // 1박스에 몇 개(박스단위)
  supplyPrice Int      @default(0) // 박스당 공급가(원) — 가맹점 납품가/결제 단가
  sortOrder   Int      @default(0)
  active       Boolean  @default(true) // false=삭제(소프트)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, sortOrder])
}

// 예약발주 — 관리자가 예약일자별로 상품(이름·점주공급가)을 등록하고, 점주(핫딜마켓)가 미리 수량 예약.
// 각 배치의 '픽업일 전날' 확정 수량이 그날 공구(TOOL) 발주에 읽기전용으로 자동 표시(단일출처).
// 일일 발주(Order)와 분리, 주간발주(WeeklyOrder) 구조를 따름.
model ReservationBatch {
  id          String   @id @default(cuid())
  reserveDate String   @unique // 예약(마감 기준) 일자 KST YYYY-MM-DD. 예약 마감 = 다음날 12:00
  pickupDate  String // 픽업 일자 KST YYYY-MM-DD. 공구 자동로드 = 픽업 전날
  active      Boolean  @default(true) // false = 배치 소프트삭제/숨김
  products    ReservationProduct[]
  orders      ReservationOrder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, reserveDate])
  @@index([pickupDate])
}

// 배치별 상품 카탈로그(관리자 등록) — WeeklyProduct 대응. 상품명 + 점주공급가.
model ReservationProduct {
  id          String           @id @default(cuid())
  batchId     String
  batch       ReservationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name        String
  supplyPrice Int              @default(0) // 점주 공급가(원) — 지금은 표시·집계용
  sortOrder   Int              @default(0)
  active      Boolean          @default(true) // false = 소프트삭제
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([batchId, active, sortOrder])
}

// 점주×배치 1건 — 확정/수정 잠금(confirmed). 마감(예약+1 12시) 후엔 강제 잠금(판정은 앱에서).
model ReservationOrder {
  id          String                 @id @default(cuid())
  batchId     String
  batch       ReservationBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  userId      String
  user        User                   @relation(fields: [userId], references: [id])
  confirmed   Boolean                @default(false)
  confirmedAt DateTime?
  items       ReservationOrderItem[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([userId, batchId]) // 점주×배치 원자적 1건
  @@index([batchId])
}

// 예약 수량 행 — WeeklyOrderItem 대응(상품 스냅샷, 카탈로그와는 productId 문자열 매칭).
model ReservationOrderItem {
  id          String           @id @default(cuid())
  orderId     String
  order       ReservationOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sortOrder   Int              @default(0)
  productId   String // ReservationProduct.id (매칭용, FK 아님 — 편집/삭제돼도 스냅샷 보존)
  name        String // 스냅샷
  supplyPrice Int              @default(0) // 스냅샷
  qty         Int              @default(0)

  @@unique([orderId, productId]) // 주문 내 상품 1행
}

// 앱 전역 메타(키-값 타임스탬프) — 예: 팝빌 계좌 최신 동기화 시각(bank_sync)
model AppMeta {
  key      String   @id
  syncedAt DateTime @default(now())
}

// 재고현황 — 새롭(본사)이 작성/구글시트 동기화, 핫딜마켓 가맹점만 열람
model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("") // (레거시) 상태/수량 텍스트 — 점진적으로 qty로 대체
  qty       Int      @default(0) // #6/#12 남은수량(시트 B열)
  supplyPrice Int    @default(0) // #6/#12 개당 공급가(시트 C열)
  memo      String   @default("")
  sortOrder Int      @default(0)
  // #12 시트 삭제 전파용 소프트삭제 마커(선택) — 현재는 미사용, 향후 tombstone
  deletedAt DateTime?
  updatedAt DateTime @updatedAt
}

// 계산서(장끼) — 새롭이 '실제 출고 기준'으로 직접 작성해 점포에 청구.
// 발주 리스트는 참고만(경매·생물 특성상 출고가 주문과 다름). 발행 후 수정 금지(취소→재작성).
model Invoice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  date   String // 출고 기준일 (KST, YYYY-MM-DD) — 합본 발주서 날짜와 동일 단위

  // kind: DAILY(일일 발주 계산서) | WEEKLY(주간발주 입금요청서) — 잠금/미수 계산이 서로 오염되지 않게 분리
  kind   String @default("DAILY")

  // status: DRAFT(작성중) | ISSUED(발행·입금대기) | PAID(입금확인) | VOID(취소)
  status String @default("DRAFT")
  total  Int    @default(0) // 합계(원) — 서버가 단가×수량으로 계산
  memo   String @default("")

  // 분할 입금 요청 — 점주가 나눠 입금하겠다고 알림(관리자 수동 확인 대상)
  splitRequested   Boolean   @default(false)
  splitRequestedAt DateTime?
  splitApprovedAt  DateTime? // 관리자가 분할 입금을 승인한 시각(null=미처리 요청)
  // 수동 입금확인 — true면 자동매칭이 되돌리지 않음(관리자 판단 우선)
  manualPaid       Boolean   @default(false)

  // #11 카테고리별 확정(부분 저장) — 확정된 카테고리 CSV(예: "FRUIT,VEG"). 4종 모두 확정돼야 발행 가능.
  confirmedCats    String    @default("")

  issuedAt DateTime?
  paidAt   DateTime?
  voidedAt DateTime?
  // 입금 기한 안내 푸시를 보낸 시각(멱등 마커 — 중복/반복 발송 방지)
  overdueRemindedAt DateTime?

  items     InvoiceItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, date])
  @@index([status, issuedAt])
  @@index([userId, kind, status])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  category  String // FRUIT | VEG | TOOL | TOFU — 카테고리별 섹션 표기
  sortOrder Int     @default(0)

  name      String // 품목
  qty       Float  @default(0) // 수량(소수 허용 — kg 등)
  unitPrice Int    @default(0) // 단가(원)
  amount    Int    @default(0) // 금액 = round(수량 × 단가), 서버 계산
}

// 입금 내역 — 팝빌 계좌조회로 수집한 하나 법인계좌 입금 건(자동 매칭 대상)
model Deposit {
  id           String    @id @default(cuid())
  bankTid      String    @unique // 팝빌 거래 고유 ID(중복 수집 방지)
  txAt         DateTime // 거래일시
  amount       Int // 입금액(원)
  payerName    String    @default("") // 입금자명(적요에서 추출)
  memo         String    @default("") // 적요/메모 원본
  balanceAfter Int? // 거래후 잔액
  // matchStatus: UNMATCHED | AUTO | MANUAL | IGNORED
  matchStatus  String    @default("UNMATCHED")
  matchedUserId String?
  matchedUser  User?     @relation(fields: [matchedUserId], references: [id], onDelete: SetNull)
  matchedAt    DateTime?
  // 이 입금이 어느 계산서 대금으로 소진됐는지(귀속). 소진된 입금은 다른 계산서 차액에 다시 안 셈.
  appliedInvoiceId String?
  createdAt    DateTime  @default(now())

  @@index([matchStatus, txAt])
  @@index([matchedUserId])
  @@index([appliedInvoiceId])
}

// 감사 로그 — 관리자의 파괴적 작업(회원삭제·발주 초기화·발주 취소·계산서 취소/입금취소 등) 추적.
// 삭제 계열은 snapshot에 삭제된 데이터 요약(JSON)을 남겨 사후 확인/복구 참고가 가능하게 한다.
model AuditLog {
  id         String   @id @default(cuid())
  action     String // member.delete | orders.resetAll | orders.cancelStore | invoice.void | invoice.unpay | order.unlock ...
  actorId    String // 실행한 관리자 id
  actorName  String   @default("") // 실행 관리자 상호/이름(사후 표시용, 비정규화 스냅샷)
  targetType String   @default("") // user | order | invoice | store ...
  targetId   String   @default("") // 대상 식별자
  summary    String   @default("") // 사람이 읽는 한 줄 요약
  snapshot   String? // 복구 참고용 JSON 스냅샷(삭제 등에서 사용)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
}
