{
  "name": "hotdeal-order",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4300",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && (prisma db seed || echo 'seed skipped') && next build",
    "start": "next start -p 4300",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:start": "/opt/homebrew/opt/postgresql@16/bin/pg_ctl -D .localpg -o '-p 5433' -l .localpg/server.log start",
    "db:stop": "/opt/homebrew/opt/postgresql@16/bin/pg_ctl -D .localpg stop"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
